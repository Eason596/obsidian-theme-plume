{
  "name": "theme-plume",
  "version": "1.0.1",
  "private": true,
  "description": "VuePress Theme Plume markdown extensions for Obsidian.",
  "license": "MIT",
  "author": "JY",
  "type": "module",
  "scripts": {
    "generate:vuepress-icons": "node scripts/generate-vuepress-file-icons.mjs",
    "generate:icons": "npm run generate:vuepress-icons",
    "dev": "npm run generate:vuepress-icons && node esbuild.config.mjs",
    "build": "npm run check && npm run generate:vuepress-icons && node esbuild.config.mjs production",
    "build:demo": "node scripts/build-demo.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:legacy": "node scripts/run-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "esbuild": "^0.25.5",
    "github-slugger": "^2.0.0",
    "happy-dom": "^20.0.10",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "obsidian": "latest",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
