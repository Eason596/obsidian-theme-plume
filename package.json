{
  "name": "obsidian-plume",
  "version": "0.2.0",
  "private": true,
  "description": "VuePress Theme Plume markdown extensions for Obsidian.",
  "license": "MIT",
  "author": "JY",
  "type": "module",
  "scripts": {
    "generate:vuepress-icons": "node scripts/generate-vuepress-file-icons.mjs",
    "generate:icons": "npm run generate:vuepress-icons && node scripts/generate-offline-icons.mjs",
    "dev": "npm run generate:icons && node esbuild.config.mjs",
    "build": "npm run check && npm run generate:icons && node esbuild.config.mjs production",
    "build:demo": "node scripts/build-demo.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:legacy": "node scripts/run-tests.mjs"
  },
  "devDependencies": {
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/file-icons": "^1.2.2",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/octicon": "^1.2.25",
    "@iconify-json/openmoji": "^1.2.27",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/vscode-icons": "^1.2.51",
    "@iconify/utils": "^3.1.3",
    "@types/node": "^20.17.57",
    "esbuild": "^0.25.5",
    "github-slugger": "^2.0.0",
    "happy-dom": "^20.0.10",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "obsidian": "latest",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
